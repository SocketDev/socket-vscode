{
  "name": "vscode-socket-security",
  "displayName": "Socket Security",
  "version": "2.0.3",
  "private": true,
  "description": "Editor integration with Socket Security",
  "categories": [
    "Linters",
    "Programming Languages"
  ],
  "keywords": [
    "Code Analysis",
    "Code Quality",
    "JavaScript",
    "Python",
    "Security",
    "Static Code Analysis",
    "TypeScript"
  ],
  "homepage": "https://socket.dev",
  "bugs": {
    "email": "support@socket.dev"
  },
  "license": "MIT",
  "repository": {
    "url": "https://github.com/SocketDev/vscode-socket-security"
  },
  "publisher": "SocketSecurity",
  "type": "commonjs",
  "main": "./out/main.js",
  "scripts": {
    "build": "rolldown -c rolldown.config.mts",
    "check": "node scripts/fleet/check.mts",
    "check:paths": "node scripts/fleet/check/paths-are-canonical.mts",
    "clean": "node -e \"require('node:fs').rmSync('node_modules/.cache', { recursive: true, force: true })\"",
    "compile": "rolldown -c rolldown.config.mts",
    "cover": "node scripts/fleet/cover.mts",
    "fix": "node scripts/fleet/fix.mts",
    "format": "node scripts/fleet/format.mts",
    "format:check": "node scripts/fleet/format.mts --check",
    "lint": "node scripts/fleet/lint.mts",
    "lockstep": "node scripts/fleet/lockstep.mts",
    "lockstep:emit-schema": "node scripts/fleet/lockstep-emit-schema.mts",
    "package-for-vscode": "vsce package --no-dependencies",
    "prepare": "node scripts/fleet/install-git-hooks.mts",
    "security": "node scripts/fleet/security.mts",
    "test": "node scripts/repo/test.mts",
    "test-compile": "tsc -p tsconfig.json",
    "update": "node scripts/fleet/update.mts",
    "vscode:prepublish": "MINIFY=1 rolldown -c rolldown.config.mts",
    "vscode:uninstall": "node ./src/lifecycle/uninstall.mjs",
    "watch": "rolldown -c rolldown.config.mts --watch",
    "setup-security-tools": "node .claude/hooks/fleet/setup-security-tools/install.mts",
    "ci:local": "node scripts/fleet/agent-ci-skip-locks.mts run --all --quiet --pause-on-failure --github-token",
    "doctor:auth": "node scripts/fleet/check/setup-is-prompt-less.mts",
    "sync-oxlint-rules": "node scripts/fleet/sync-oxlint-rules.mts",
    "sync-package-manager-pins": "node scripts/fleet/sync-package-manager-pins.mts",
    "weekly-update": "node scripts/fleet/weekly-update.mts",
    "weekly-update:ci": "node scripts/fleet/weekly-update-workflow.mts run",
    "doctor": "node scripts/fleet/doctor.mts",
    "gen:llms-txt": "node scripts/fleet/make-llms-txt.mts --no-ai",
    "setup:brew": "node scripts/fleet/setup/setup-brew.mts",
    "setup:go": "node scripts/fleet/setup/setup-go.mts",
    "setup:mcp": "node scripts/fleet/setup/setup-mcp.mts",
    "setup:python": "node scripts/fleet/setup/setup-python.mts",
    "setup:refero": "node scripts/fleet/setup/setup-refero.mts",
    "setup:rust": "node scripts/fleet/setup/setup-rust.mts"
  },
  "dependencies": {
    "@socketsecurity/lib": "catalog:",
    "@vscode/python-extension": "1.0.6",
    "acorn-wasm": "workspace:*",
    "ini": "6.0.0",
    "json-wasm": "workspace:*",
    "toml-wasm": "workspace:*"
  },
  "devDependencies": {
    "@redwoodjs/agent-ci": "catalog:",
    "@sinclair/typebox": "catalog:",
    "@socketregistry/packageurl-js": "catalog:",
    "@socketregistry/packageurl-js-stable": "catalog:",
    "@socketsecurity/lib-stable": "catalog:",
    "@socketsecurity/sdk": "catalog:",
    "@socketsecurity/sdk-stable": "catalog:",
    "@types/ini": "4.1.1",
    "@types/mdast": "catalog:",
    "@types/node": "catalog:",
    "@types/semver": "catalog:",
    "@types/shell-quote": "catalog:",
    "@types/vscode": "1.118.0",
    "@typescript/native-preview": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "@vitest/ui": "catalog:",
    "@vscode/vsce": "3.9.1",
    "c8": "catalog:",
    "chrome-devtools-mcp": "catalog:",
    "impeccable": "catalog:",
    "magic-string": "catalog:",
    "markdownlint-cli2": "catalog:",
    "mdast-util-from-markdown": "catalog:",
    "micromark": "catalog:",
    "neosanitize": "catalog:",
    "nock": "catalog:",
    "npm-run-all2": "catalog:",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "playwright-core": "catalog:",
    "regjsparser": "catalog:",
    "rolldown": "catalog:",
    "semver": "catalog:",
    "shell-quote": "catalog:",
    "svgo": "catalog:",
    "taze": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "contributes": {
    "configuration": {
      "title": "Socket Security",
      "properties": {
        "socket-security.pythonInterpreter": {
          "order": 1,
          "type": "string",
          "description": "Path to a Python interpreter to use for Socket dependency analysis.",
          "examples": [
            "/usr/bin/python"
          ]
        },
        "socket-security.goExecutable": {
          "order": 2,
          "type": "string",
          "description": "Path to a Go executable to use for Socket dependency analysis.",
          "examples": [
            "/usr/bin/go"
          ]
        }
      }
    },
    "commands": [
      {
        "title": "Login",
        "category": "Socket Security",
        "command": "socket-security.login"
      }
    ],
    "mcpServerDefinitionProviders": [
      {
        "id": "socket-security.mcp-server",
        "label": "[Extension] Socket Security"
      }
    ]
  },
  "activationEvents": [
    "onLanguage:go",
    "onLanguage:javascript",
    "onLanguage:javascriptreact",
    "onLanguage:python",
    "onLanguage:typescript",
    "onLanguage:typescriptreact",
    "workspaceContains:**/[gG][oO].[mM][oO][dD]",
    "workspaceContains:**/[gG][oO].[sS][uU][mM]",
    "workspaceContains:**/[pP][aA][cC][kK][aA][gG][eE].[jJ][sS][oO][nN]",
    "workspaceContains:**/[pP][iI][pP][fF][iI][lL][eE]",
    "workspaceContains:**/[pP][yY][pP][rR][oO][jJ][eE][cC][tT].[tT][oO][mM][lL]",
    "workspaceContains:**/[rR][eE][qQ][uU][iI][rR][eE][mM][eE][nN][tT][sS].[tT][xX][tT]"
  ],
  "icon": "assets/socket-icon-brand-256.png",
  "preview": false,
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": ">=11.0.0 <12.0.0",
      "onFail": "error"
    }
  },
  "engines": {
    "node": ">=24",
    "npm": ">=12.0.0",
    "pnpm": ">=11.0.5",
    "vscode": "^1.63.0"
  },
  "allowScripts": {
    "cpu-features": false,
    "esbuild": true,
    "keytar": true,
    "protobufjs": false,
    "ssh2": false
  },
  "npm-run-all2": {
    "nodeRun": true
  },
  "tags": [
    "Code Analysis",
    "Code Quality",
    "JavaScript",
    "Python",
    "Security",
    "Static Code Analysis",
    "TypeScript"
  ]
}
